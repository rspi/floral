{
  "name": "floral",
  "version": "0.0.1",
  "description": "Web component based design system",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#test-helper": "./test-helper.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=10000 components/**/*.test.js",
    "test:install": "npx playwright install chromium",
    "skills:package": "node ./.gemini/scripts/package_skill.cjs ./.gemini/skills/floral-test-writer ./.gemini/dist",
    "skills:install": "gemini skills install ./.gemini/dist/floral-test-writer.skill --scope workspace",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath .githooks",
    "start": "node dev-server.js"
  },
  "devDependencies": {
    "playwright-core": "^1.42.1",
    "prettier": "^3.8.1"
  },
  "author": "Rasmus Spiegelberg",
  "license": "ISC"
}
