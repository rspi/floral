{
  "name": "floral",
  "version": "0.0.1",
  "description": "Web component based design system",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#test-helper": "./test-helper.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=10000 utils.test.js components/**/*.test.js",
    "test:install": "npx playwright-core install chromium",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config core.hooksPath .githooks",
    "start": "node dev-server.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.1"
  },
